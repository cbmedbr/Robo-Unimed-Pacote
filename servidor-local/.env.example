# Configuração do servidor local Unimed.
# Copie este arquivo para `.env` e preencha os valores.

# ============================================================================
# Supabase — credenciais para ler/atualizar jobs
# ============================================================================
# URL do projeto. Achei em: https://supabase.com/dashboard/project/fptpcfdyzjlemjuiyaxw/settings/api
SUPABASE_URL=https://fptpcfdyzjlemjuiyaxw.supabase.co

# Service role key. ATENÇÃO: nunca compartilhe nem suba pro git.
# Pega em: https://supabase.com/dashboard/project/fptpcfdyzjlemjuiyaxw/settings/api
# Use a "service_role" key, NÃO a "anon" key. Service role bypassa RLS.
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================================
# Unimed — credenciais do portal SGU-Card
# ============================================================================
UNIMED_USUARIO=300788
UNIMED_SENHA=

# ============================================================================
# Robô — caminho do projeto e configuração
# ============================================================================
# Caminho absoluto pra pasta do robô (unimed-mvp-final).
# No Windows, use barras invertidas duplas: C:\\Users\\55489\\unimed-mvp
ROBO_CAMINHO=C:\\Users\\55489\\Downloads\\unimed-mvp\\unimed-mvp

# Quanto tempo (ms) aguardar antes de matar um job em execução.
ROBO_TIMEOUT_MS=180000

# Headless (true) ou visível (false). Recomendo false pra recepcionista
# acompanhar visualmente o robô trabalhando.
ROBO_HEADLESS=false

# ============================================================================
# Servidor HTTP
# ============================================================================
# Porta do servidor. Se 9876 estiver ocupada, ajuste aqui.
PORT=9876

# Origem do CRM pra liberar CORS. Pode ser múltiplas separadas por vírgula.
CORS_ORIGINS=https://crm-luciano-noceti.vercel.app,http://localhost:5173
